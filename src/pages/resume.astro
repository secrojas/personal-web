---
import ResumeLayout from "@/layouts/ResumeLayout.astro";
import Header from "@/components/resume/Header.astro";
import WorkExperience from "@/components/resume/WorkExperience.astro";
import Education from "@/components/resume/Education.astro";
import Skills from "@/components/resume/Skills.astro";
import Certifications from "@/components/resume/Certifications.astro";
import Projects from "@/components/resume/Projects.astro";
import Section from "@/components/ui/Section.astro";
import { CommandMenu } from "@/components/resume/CommandMenu";
import { RESUME_DATA } from "@/data/resume-data";

const title = `${RESUME_DATA.name} | Resume`;
const description = RESUME_DATA.summary;

const commandMenuLinks = [
  {
    url: RESUME_DATA.personalWebsiteUrl,
    title: "Personal Website",
  },
  ...RESUME_DATA.contact.social.map((social) => ({
    url: social.url,
    title: social.name,
  })),
];
---

<ResumeLayout title={title} description={description}>
  <main class="container relative mx-auto scroll-my-12 overflow-auto p-4 print:p-12 md:p-16">
    <section class="mx-auto w-full max-w-2xl space-y-8 bg-background print:space-y-6 print:bg-white">
      <Header />

      <Section>
        <h2 class="text-xl font-bold">About</h2>
        <p class="text-pretty font-mono text-sm text-muted-foreground">
          {RESUME_DATA.summary}
        </p>
      </Section>

      <WorkExperience />
      <Education />
      <Skills />
      <Certifications />
      <Projects />
    </section>

    <!-- Back to portfolio link -->
    <div class="mx-auto mt-8 max-w-2xl text-center print:hidden">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground"
      >
        <svg
          class="size-4"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        Back to Portfolio
      </a>
    </div>

    <!-- Command Menu (React island) -->
    <CommandMenu client:load links={commandMenuLinks} />
  </main>
</ResumeLayout>
