---
import PortfolioLayout from "@/layouts/PortfolioLayout.astro";
import Hero from "@/components/portfolio/Hero.astro";
import About from "@/components/portfolio/About.astro";
import TechStack from "@/components/portfolio/TechStack.astro";
import Experience from "@/components/portfolio/Experience.astro";
import Projects from "@/components/portfolio/Projects.astro";
import Contact from "@/components/portfolio/Contact.astro";
import { RESUME_DATA } from "@/data/resume-data";

const title = `${RESUME_DATA.name} | ${RESUME_DATA.about}`;
const description = RESUME_DATA.summary;
---

<PortfolioLayout title={title} description={description}>
  <Hero />
  <About />
  <TechStack />
  <Experience />
  <Projects />
  <Contact />
</PortfolioLayout>
