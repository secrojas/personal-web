---
import { RESUME_DATA } from "@/data/resume-data";
import Section from "@/components/ui/Section.astro";
import Badge from "@/components/ui/Badge.astro";
import ExternalLinkIcon from "@/components/icons/ExternalLinkIcon.astro";
---

<Section class="py-20 px-4 bg-secondary/30">
  <div class="container mx-auto max-w-4xl">
    <h2 class="mb-12 text-3xl font-bold text-foreground text-center">
      Featured Projects
    </h2>

    <div class="grid gap-6 md:grid-cols-2">
      {
        RESUME_DATA.projects.map((project) => (
          <div class="group rounded-lg border border-border bg-card p-6 transition-all hover:border-primary/50 hover:shadow-lg">
            <div class="mb-4 flex items-start justify-between">
              <h3 class="text-lg font-semibold text-foreground">
                {project.link ? (
                  <a
                    href={project.link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 hover:underline"
                  >
                    {project.title}
                    <span class="size-2 rounded-full bg-green-500" />
                  </a>
                ) : (
                  project.title
                )}
              </h3>
              {project.link && (
                <a
                  href={project.link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-muted-foreground transition-colors hover:text-foreground"
                  aria-label={`Visit ${project.title}`}
                >
                  <ExternalLinkIcon class="size-4" />
                </a>
              )}
            </div>

            <p class="mb-4 text-sm text-muted-foreground">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {project.techStack.map((tech) => (
                <Badge variant="secondary" class="text-xs">
                  {tech}
                </Badge>
              ))}
            </div>
          </div>
        ))
      }

      <!-- Placeholder for more projects -->
      <div class="flex items-center justify-center rounded-lg border border-dashed border-border p-6">
        <div class="text-center">
          <p class="mb-2 text-muted-foreground">More projects coming soon</p>
          <a
            href="https://github.com/secrojas"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-primary hover:underline"
          >
            Check my GitHub →
          </a>
        </div>
      </div>
    </div>
  </div>
</Section>
